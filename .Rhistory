segment.linetype = 3,
show.legend = FALSE)+
# add point labels for 2019
geom_point(data = df_incidence_rate_2019,
show.legend = F)+
# add text labels for 2019
geom_text_repel(data = df_incidence_rate_2019,
aes(label = incident_label),
nudge_x = -1.4,
direction = "y",
hjust = 1,
vjust = 0.5,
segment.linetype = 3,
show.legend = FALSE)+
scale_color_manual(values = fill_color)+
scale_x_continuous(breaks = pretty(range(df_incidence_rate$onset_year), n = 5),
expand = expansion(add = c(0.5, 1.5)))+
scale_y_continuous(labels = scales::comma,
breaks = plot_breaks,
limits = range(plot_breaks),
expand = expansion(mult = c(0, 0)))+
theme_bw()+
theme(plot.title.position = 'plot',
legend.position = 'inside',
legend.position.inside = c(0.01, 0.6),
legend.justification = c(0, 0.5))+
labs(title = 'B',
x = 'Year',
y = 'Incidence rate',
color = 'Age group')
## proportion of incidence -----------------------------------------------------
fig3 <- df_incidence_proportion |>
ggplot(aes(x = onset_year, y = proportion, fill = age_group)) +
geom_col(position = 'stack')+
scale_fill_manual(values = fill_color)+
scale_x_continuous(breaks = pretty(range(df_incidence_proportion$onset_year), n = 6),
expand = expansion(add = c(0.15, 0.15)))+
scale_y_continuous(labels = scales::percent,
limits = c(0, 1),
expand = expansion(mult = c(0, 0)))+
theme_bw()+
theme(plot.title.position = 'plot',
legend.position = 'none')+
labs(title = 'C',
x = 'Year',
y = 'Proportion of cases',
fill = 'Age group')
## cumulative proportion of incidence ----------------------------------------
fig4 <- df_incidence_cumulative |>
ggplot(aes(x = age_group, y = cumulative_proportion, color = onset_year, group = onset_year)) +
geom_line()+
scale_color_gradientn(limits = range(df_incidence_cumulative$onset_year),
breaks = pretty(range(df_incidence_cumulative$onset_year), n = 6),
colors = paletteer_d("MetBrewer::Hiroshige", direction = -1))+
scale_x_discrete(limits = levels(df_incidence_cumulative$age_group),
expand = expansion(add = c(0.15, 0.15)))+
scale_y_continuous(labels = scales::percent,
limits = c(0, 1),
expand = expansion(mult = c(0, 0)))+
theme_bw()+
theme(plot.title.position = 'plot',
legend.position = 'inside',
legend.direction = 'horizontal',
legend.position.inside = c(0.6, 0.1),
legend.justification = c(0.5, 0))+
labs(title = 'D',
x = 'Age group',
y = 'Cumulative proportion of cases',
color = 'Year')+
# setting guides range
guides(color = guide_colorbar(barwidth = 15, barheight = 1))
# save figures -----------------------------------------------------------------
fig <- fig1 + fig2 + fig3 + fig4 +
plot_layout(widths = c(1, 1), heights = c(1, 1), ncol = 2, byrow = TRUE)
ggsave('./outcome/p1_incidence.png',
fig, width = 12, height = 8, dpi = 300)
fig
# packages ---------------------------------------------------------------------
library(tidyverse)
library(openxlsx)
library(patchwork)
library(ggrepel)
library(paletteer)
library(Cairo)
fill_color <- paletteer_d("unikn::pal_unikn_pref")
# data -------------------------------------------------------------------------
# load data
df_2010_2020 <- read.csv('D:/app/OneDrive/Desktop/04 百日咳新策略/data/incidence_2010_2020.csv')
df_2020_2023 <- read.csv('D:/app/OneDrive/Desktop/04 百日咳新策略/data/incidence_2020_2023.csv')
df_2025 <- read.csv('D:/app/OneDrive/Desktop/04 百日咳新策略/data/incidence_2025.csv')
df_population <- read.xlsx('D:/app/OneDrive/Desktop/04 百日咳新策略/data/population_2010_2024.xlsx')
# combine data
df <- rbind(df_2010_2020, df_2020_2023, df_2025)
rm(df_2010_2020, df_2020_2023, df_2025)
# data clean -------------------------------------------------------------------
# get total population in different years, from 2010 to 2024
df_population_clean <- df_population |>
filter(Age == "0+") |>
select(Year, Population)
df_clean <- df  |>
rename(age = `年龄`, onset_date = `发病日期`) |>
# add new columns "onset_year", "onset_month", "age_num", "age_group"
mutate(onset_date = as.Date(onset_date, format = '%Y/%m/%d'),
onset_year = year(onset_date),
onset_month = month(onset_date),
age_num = case_when(str_detect(age, '岁') ~ as.numeric(str_remove(age, '岁')),
str_detect(age, '月') ~ as.numeric(str_remove(age, '月')) / 12,
str_detect(age, '天') ~ 1/12,
TRUE ~ as.numeric(age)),
age_group = cut(age_num,
breaks = c(0, 0.5, 2, 6, 10, 20, Inf),
labels = c('[0,0.5)','[0.5,2)', '[2,6)', '[6,10)', '[10,20)','20+'),
include.lowest = TRUE,
right = FALSE)) |>
# filter out rows with missing values in "age" and "onset_date", or "onset_year" < 2010
filter(!is.na(age), !is.na(onset_date), onset_year >= 2010)
# calculate incidence monthly
df_incidence_monthly <- df_clean |>
group_by(onset_year, onset_month, age_group) |>
summarise(n = n(),
.groups = 'drop') |>
# complete the data frame with all combinations of "onset_year", "onset_month" and "age_group"
complete(onset_year, onset_month, age_group, fill = list(n = 0)) |>
# create a new column "onset_date" with the first day of the month
mutate(onset_date = as.Date(paste(onset_year, onset_month, '01', sep = '-')))
# calculate incidence rate
df_incidence_rate <- df_clean |>
group_by(onset_year, age_group) |>
summarise(n = n(),
.groups = 'drop') |>
# complete the data frame with all combinations of "onset_year" and "age_group"
complete(onset_year, age_group, fill = list(n = 0)) |>
# join with population data
left_join(df_population_clean, by = c('onset_year' = 'Year')) |>
# calculate incidence rate
mutate(incidence = n / (Population * 0.1)) |>
# drop columns "n" and "Population"
select(-n, -Population)
# calculate proportion of incidence
df_incidence_proportion <- df_clean |>
group_by(onset_year, age_group) |>
summarise(n = n(),
.groups = 'drop') |>
# complete the data frame with all combinations of "onset_year" and "age_group"
complete(onset_year, age_group, fill = list(n = 0)) |>
# group by "onset_year"
group_by(onset_year) |>
mutate(proportion = n / sum(n)) |>
ungroup() |>
# drop column "n"
select(-n)
# calculate cumulative proportion of incidence
df_incidence_cumulative <- df_clean |>
group_by(onset_year, age_group) |>
summarise(n = n(),
.groups = 'drop') |>
# complete the data frame with all combinations of "onset_year" and "age_group"
complete(onset_year, age_group, fill = list(n = 0)) |>
# group by "onset_year"
group_by(onset_year) |>
mutate(cumulative_proportion = cumsum(n) / sum(n)) |>
ungroup() |>
# drop column "n"
select(-n)
# visualization ----------------------------------------------------------------
## monthly incidence -----------------------------------------------------------
df_incidence_annual <- df_incidence_monthly |>
group_by(onset_date) |>
summarise(n = sum(n),
.groups = 'drop')
plot_breaks <- pretty(range(df_incidence_annual$n), n = 6)
fig1 <- df_incidence_monthly |>
ggplot(aes(x = onset_date, y = n, fill = age_group)) +
geom_col(position = 'stack')+
scale_fill_manual(values = fill_color)+
scale_x_date(date_labels = '%Y',
expand = expansion(add = c(1, 31)))+
scale_y_continuous(breaks = plot_breaks,
limits = range(plot_breaks),
labels = scales::comma,
expand = expansion(mult = c(0, 0)))+
theme_bw()+
theme(plot.title.position = 'plot',
legend.position = 'inside',
legend.position.inside = c(0.01, 0.6),
legend.justification = c(0, 0.5))+
labs(title = 'A',
x = 'Year',
y = 'Monthly incidence',
fill = 'Age group')
## incidence rate --------------------------------------------------------------
plot_breaks <- pretty(range(df_incidence_rate$incidence), n = 6)
df_incidence_rate_last_year <- df_incidence_rate |>
filter(onset_year == max(onset_year)) |>
mutate(incident_label = scales::comma(incidence, 0.01))
df_incidence_rate_2019 <- df_incidence_rate |>
filter(onset_year == 2019) |>
mutate(incident_label = scales::comma(incidence, 0.01))
fig2 <- df_incidence_rate |>
ggplot(aes(x = onset_year, y = incidence, color = age_group)) +
geom_line()+
# add point labels for the last year
geom_point(data = df_incidence_rate_last_year,
show.legend = F)+
# add text labels for the last year
geom_text_repel(data = df_incidence_rate_last_year,
aes(label = incident_label),
nudge_x = 0.4,
direction = "y",
hjust = 0,
segment.linetype = 3,
show.legend = FALSE)+
# add point labels for 2019
geom_point(data = df_incidence_rate_2019,
show.legend = F)+
# add text labels for 2019
geom_text_repel(data = df_incidence_rate_2019,
aes(label = incident_label),
nudge_x = -1.4,
direction = "y",
hjust = 1,
vjust = 0.5,
segment.linetype = 3,
show.legend = FALSE)+
scale_color_manual(values = fill_color)+
scale_x_continuous(breaks = pretty(range(df_incidence_rate$onset_year), n = 5),
expand = expansion(add = c(0.5, 1.5)))+
scale_y_continuous(labels = scales::comma,
breaks = plot_breaks,
limits = range(plot_breaks),
expand = expansion(mult = c(0, 0)))+
theme_bw()+
theme(plot.title.position = 'plot',
legend.position = 'inside',
legend.position.inside = c(0.01, 0.6),
legend.justification = c(0, 0.5))+
labs(title = 'B',
x = 'Year',
y = 'Incidence rate',
color = 'Age group')
## proportion of incidence -----------------------------------------------------
fig3 <- df_incidence_proportion |>
ggplot(aes(x = onset_year, y = proportion, fill = age_group)) +
geom_col(position = 'stack')+
scale_fill_manual(values = fill_color)+
scale_x_continuous(breaks = pretty(range(df_incidence_proportion$onset_year), n = 6),
expand = expansion(add = c(0.15, 0.15)))+
scale_y_continuous(labels = scales::percent,
limits = c(0, 1),
expand = expansion(mult = c(0, 0)))+
theme_bw()+
theme(plot.title.position = 'plot',
legend.position = 'none')+
labs(title = 'C',
x = 'Year',
y = 'Proportion of cases',
fill = 'Age group')
## cumulative proportion of incidence ----------------------------------------
fig4 <- df_incidence_cumulative |>
ggplot(aes(x = age_group, y = cumulative_proportion, color = onset_year, group = onset_year)) +
geom_line()+
scale_color_gradientn(limits = range(df_incidence_cumulative$onset_year),
breaks = pretty(range(df_incidence_cumulative$onset_year), n = 6),
colors = paletteer_d("MetBrewer::Hiroshige", direction = -1))+
scale_x_discrete(limits = levels(df_incidence_cumulative$age_group),
expand = expansion(add = c(0.15, 0.15)))+
scale_y_continuous(labels = scales::percent,
limits = c(0, 1),
expand = expansion(mult = c(0, 0)))+
theme_bw()+
theme(plot.title.position = 'plot',
legend.position = 'inside',
legend.direction = 'horizontal',
legend.position.inside = c(0.6, 0.1),
legend.justification = c(0.5, 0))+
labs(title = 'D',
x = 'Age group',
y = 'Cumulative proportion of cases',
color = 'Year')+
# setting guides range
guides(color = guide_colorbar(barwidth = 15, barheight = 1))
# save figures -----------------------------------------------------------------
fig <- fig1 + fig2 + fig3 + fig4 +
plot_layout(widths = c(1, 1), heights = c(1, 1), ncol = 2, byrow = TRUE)
ggsave('./outcome/p1_incidence.png',
fig, width = 12, height = 8, dpi = 300)
ggsave('./outcome/p1_incidence.pdf',
fig, width = 12, height = 8,
device = cairo_pdf)
write.xlsx(list('A' = df_incidence_monthly,
'B' = df_incidence_rate,
'C' = df_incidence_proportion,
'D' = df_incidence_cumulative),
'p1_incidence_monthly.xlsx')
